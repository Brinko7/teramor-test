[gd_resource type="Resource" script_class="NpcData" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/npc_data.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/placeholder/npc_warden.png" id="2_tex"]

[resource]
script = ExtResource("1_script")
id = &"sorrel"
display_name = "Hooded Woman"
title = "A Stranger by the Hearth"
sprite_texture = ExtResource("2_tex")
tint = Color(0.55, 0.62, 0.5, 1)
met_line = "Don't look so startled. Sit — you'll draw less notice sitting. ...There. You've his eyes, you know. Elkar's. I'd know them in the dark."
greeting = "Quietly, now. Walls in a tavern have more ears than a field of wheat."
farewell = "Go careful. And tell no one a hooded woman bought you a thought."
talk_lines = {
0: PackedStringArray("I knew your father. That's all you need of my name for now.", "You came asking after Elkar at every door in the Landing. Loudly. We heard.")
}
topics = Array[Dictionary]([{
"label": "You knew my father?",
"lines": PackedStringArray("I did. We share a... calling, your father and I. Older than the kingdoms, and quieter.", "He took the baron's contract as cover. His true road led elsewhere — and he has not come back from it.", "I can't say more under this roof. But there are those who can.")
}, {
"label": "Then tell me where he went.",
"lines": PackedStringArray("Not here. Not aloud.", "North of the Landing, behind this tavern, the old oaks lean together over a deer-path. Most walk past it. You won't.", "Follow it into the green. Don't turn back when the wood grows close — it tests the faint-hearted. At its end you'll find people who knew Elkar as we did.", "They are expecting you. They have been, since before you were born. Go, child of Tera — and learn what became of your father."),
"set_flag": "trail_revealed"
}])
