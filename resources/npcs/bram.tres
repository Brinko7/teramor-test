[gd_resource type="Resource" script_class="NpcData" load_steps=3 format=3]

[ext_resource type="Script" path="res://scripts/npc_data.gd" id="1_script"]
[ext_resource type="Texture2D" path="res://assets/placeholder/npc_bram.png" id="2_tex"]

[resource]
script = ExtResource("1_script")
id = &"bram"
display_name = "Bram"
title = "Camp Farmhand"
sprite_texture = ExtResource("2_tex")
tint = Color(1, 1, 1, 1)
met_line = "New face! I'm Bram. I keep the plots turning over — somebody's got to, eh? You ever need dirt under your nails, you come find me."
greeting = "Back from the wilds, then? The soil missed you."
farewell = "Go on, I've rows to weed."
talk_lines = {
0: PackedStringArray("Turnips coming in nice this season. Honest work, this.", "My old farm's gone — burned in the troubles. But a seed's a seed, anywhere you put it."),
2: PackedStringArray("You've a steady hand for someone who swings a sword all day.", "Give me a full water-barrel and a clear morning and I'm a happy man."),
4: PackedStringArray("Tell you what, Zayn — this camp's the closest thing to home I've had since.", "Anything grows here, we grow it together. That's the deal.")
}
loved_gifts = Array[StringName]([&"turnip"])
liked_gifts = Array[StringName]([&"wood", &"herb"])
disliked_gifts = Array[StringName]([&"rusty_sword"])
loved_line = "A turnip from the field! Ha — you're a farmer at heart, I knew it. Thank you."
liked_line = "A %s? That'll come in handy. Cheers, Zayn."
disliked_line = "A %s? ...not much use to me in the rows, but I'll take the thought."
neutral_line = "For me? Kind of you."
recruitable = true
recruit_role = &"farmhand"
recruit_hearts = 2
recruit_label = "Would you tend the farm while I'm away?"
recruit_accept = "Say no more. I'll keep every plot watered and bring the ripe ones to the stash. Go do what you do — the field's mine."
topics = Array[Dictionary]([{
"label": "How's the harvest?",
"lines": PackedStringArray("Slow and steady. Water 'em, wait, watch 'em swell. No shortcuts that last.", "Get me a few more hands and we could feed the whole camp off these rows.")
}])
