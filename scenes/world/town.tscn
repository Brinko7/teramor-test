[node name="Child" parent="Entities" instance=ExtResource("14_npc")]
position = Vector2(1040, 830)
speaker_name = "Town Child"
lines = PackedStringArray("Are you a real ranger? Like Elkar?", "He used to carve me little foxes. I hope he comes home.")
