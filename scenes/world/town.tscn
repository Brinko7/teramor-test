[node name="Villager" parent="Entities" instance=ExtResource("14_npc")]
position = Vector2(870, 800)
speaker_name = "Townswoman"
lines = PackedStringArray("Wolves came right up to the fences last week. It isn't natural.", "If you're after work, Bram keeps the board at the Stag well stocked.")
