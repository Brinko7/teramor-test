; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Teramor"
run/main_scene="res://scenes/ui/main_menu.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="res://resources/audio/default_bus_layout.tres"

[autoload]

Events="*res://scripts/autoload/events.gd"
CombatFX="*res://scripts/autoload/combat_fx.gd"
AudioManager="*res://scripts/autoload/audio_manager.gd"
GameManager="*res://scripts/autoload/game_manager.gd"
PlayerProfile="*res://scripts/autoload/player_profile.gd"
Relationships="*res://scripts/autoload/relationship_manager.gd"
TimeManager="*res://scripts/autoload/time_manager.gd"
SceneManager="*res://scripts/autoload/scene_manager.gd"
Wallet="*res://scripts/autoload/wallet.gd"
SaveManager="*res://scripts/autoload/save_manager.gd"
QuestManager="*res://scripts/autoload/quest_manager.gd"
FarmManager="*res://scripts/autoload/farm_manager.gd"
StorageManager="*res://scripts/autoload/storage_manager.gd"
Skills="*res://scripts/autoload/skills.gd"
WorldMap="*res://scripts/autoload/world_map.gd"
TravelManager="*res://scripts/autoload/travel_manager.gd"
Story="*res://scripts/autoload/story.gd"
UIManager="*res://scripts/autoload/ui_manager.gd"
CampManager="*res://scripts/autoload/camp_manager.gd"
HeartEventManager="*res://scripts/autoload/heart_event_manager.gd"
SeasonManager="*res://scripts/autoload/season_manager.gd"
MusicManager="*res://scripts/autoload/music_manager.gd"
SettingsManager="*res://scripts/autoload/settings_manager.gd"
_mcp_game_helper="*res://addons/godot_ai/runtime/game_helper.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_ai/plugin.cfg")

[gui]

theme/custom="res://resources/ui/teramor_theme.tres"

